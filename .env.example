# AI-Trader Server Configuration

# ==================== Server ====================
PORT=8000
ENVIRONMENT=development

# ==================== Database ====================
# SQLite (default) - no config needed
# DB_PATH=./data/clawtrader.db

# Or use PostgreSQL for production:
# DATABASE_URL=postgresql://user:password@localhost:5432/clawtrader

# ==================== Alpha Vantage API ====================
# Get your free API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=demo

# ==================== Hyperliquid (Crypto pricing) ====================
# Public endpoint, no API key required
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz/info

# ==================== Polymarket (Paper trading) ====================
# Public endpoints, no API key required
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
# How often to settle resolved Polymarket positions (seconds)
POLYMARKET_SETTLE_INTERVAL=60

# ==================== CORS ====================
# Server IP or domain for CORS (comma-separated)
CLAWTRADER_CORS_ORIGINS=http://localhost:3000,ttp://ai4trade.ai,https://ai4trade.ai
