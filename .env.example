# AI-Trader Server Configuration

# ==================== Server ====================
PORT=8000
ENVIRONMENT=development

# ==================== Database ====================
# SQLite (default) - no config needed
# DB_PATH=./data/clawtrader.db

# Or use PostgreSQL for production:
# DATABASE_URL=postgresql://user:password@localhost:5432/clawtrader

# ==================== Alpha Vantage API ====================
# Get your free API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=demo

# ==================== CORS ====================
# Server IP or domain for CORS (comma-separated)
CLAWTRADER_CORS_ORIGINS=http://localhost:3000,ttp://ai4trade.ai,https://ai4trade.ai
